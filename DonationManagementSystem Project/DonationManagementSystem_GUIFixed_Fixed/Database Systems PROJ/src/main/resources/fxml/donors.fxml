<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dms.controllers.DonorsController"
      styleClass="content-bg">

    <!-- Header -->
    <VBox styleClass="content-header">
        <Label text="Donors" styleClass="page-title"/>
        <Label text="Manage donor records" styleClass="page-subtitle"/>
    </VBox>

    <!-- Toolbar: Search + Primary actions -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <padding><Insets top="16" right="24" bottom="4" left="24"/></padding>

        <!-- Fix #16: live search fires on key-release, no button needed -->
        <TextField fx:id="searchField" promptText="🔍  Search name, email or phone…"
                   prefWidth="260" onKeyReleased="#searchByName"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Primary action -->
        <Button text="＋  Add Donor" onAction="#openAddDialog" styleClass="btn-primary"/>

        <!-- Secondary actions grouped -->
        <Button text="Edit"    onAction="#openEditDialog"    styleClass="btn-warning"/>
        <Button text="Profile" onAction="#viewDetails"       styleClass="btn-accent"/>
        <Button text="Log Comm." onAction="#sendCommunication" styleClass="btn-accent"/>
        <Button text="Tag"     onAction="#assignTag"         styleClass="btn-accent"/>

        <!-- Destructive — visually separated by a spacer -->
        <Separator orientation="VERTICAL" style="-fx-padding: 0 4;"/>
        <Button text="🗑  Delete" onAction="#deleteDonor" styleClass="btn-danger"/>
    </HBox>

    <!-- Table -->
    <VBox VBox.vgrow="ALWAYS">
        <padding><Insets top="8" right="24" bottom="0" left="24"/></padding>
        <TableView fx:id="donorTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colName"  text="Name"  prefWidth="220"/>
                <TableColumn fx:id="colEmail" text="Email" prefWidth="260"/>
                <TableColumn fx:id="colPhone" text="Phone" prefWidth="160"/>
                <TableColumn fx:id="colType"  text="Type"  prefWidth="100"/>
            </columns>
        </TableView>
    </VBox>

    <!-- Fix #16: Pagination bar -->
    <HBox fx:id="paginationBar" spacing="8" alignment="CENTER_RIGHT">
        <padding><Insets top="8" right="24" bottom="14" left="24"/></padding>
        <Label fx:id="lblPageInfo" style="-fx-font-size:12px; -fx-text-fill:#64748b;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnPrevPage" text="‹  Prev" onAction="#prevPage"
                style="-fx-background-color:#e2e8f0; -fx-background-radius:6; -fx-cursor:hand; -fx-padding:5 14;"/>
        <Button fx:id="btnNextPage" text="Next  ›" onAction="#nextPage"
                style="-fx-background-color:#e2e8f0; -fx-background-radius:6; -fx-cursor:hand; -fx-padding:5 14;"/>
    </HBox>

</VBox>
