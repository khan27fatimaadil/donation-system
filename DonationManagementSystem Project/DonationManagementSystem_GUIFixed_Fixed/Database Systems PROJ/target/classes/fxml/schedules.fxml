<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dms.controllers.SchedulesController"
      styleClass="content-bg">

    <!-- Header -->
    <VBox styleClass="content-header">
        <Label text="Recurring Schedules" styleClass="page-title"/>
        <Label text="Manage recurring donation schedules" styleClass="page-subtitle"/>
    </VBox>

    <!-- Toolbar -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <padding><Insets top="16" right="24" bottom="12" left="24"/></padding>
        <Button text="Add Schedule"  onAction="#openAddDialog"  styleClass="btn-primary"/>
        <Button text="Edit"          onAction="#openEditDialog" styleClass="btn-warning"/>
        <Button text="Toggle Active" onAction="#toggleActive"   styleClass="btn-warning"/>
        <Button text="Delete"        onAction="#deleteSchedule" styleClass="btn-danger"/>
    </HBox>

    <!-- Table -->
    <VBox VBox.vgrow="ALWAYS">
        <padding><Insets top="0" right="24" bottom="24" left="24"/></padding>
        <TableView fx:id="scheduleTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colDonorName" text="Donor Name"      prefWidth="180"/>
                <TableColumn fx:id="colCause"     text="Cause"           prefWidth="160"/>
                <TableColumn fx:id="colFrequency" text="Frequency"       prefWidth="110"/>
                <TableColumn fx:id="colNextDue"   text="Next Due Date"   prefWidth="130"/>
                <TableColumn fx:id="colStatus"    text="Status"          prefWidth="110"/>
            </columns>
        </TableView>
    </VBox>

</VBox>
