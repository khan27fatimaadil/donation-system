<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dms.controllers.DonationEntryController"
      styleClass="content-bg">

    <!-- Header -->
    <VBox styleClass="content-header">
        <Label text="New Donation" styleClass="page-title"/>
        <Label text="Record a new donation transaction" styleClass="page-subtitle"/>
    </VBox>

    <!-- Form Card -->
    <VBox VBox.vgrow="ALWAYS">
        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
        <VBox styleClass="card" spacing="16" maxWidth="560">

            <Label text="Donation Details" styleClass="section-label"/>

            <GridPane hgap="16" vgap="14">
                <Label text="Donor *" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <ComboBox fx:id="donorCombo" prefWidth="320"
                          promptText="Select donor..."
                          GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Cause / Campaign *" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <ComboBox fx:id="causeCombo" prefWidth="320"
                          promptText="Select campaign..."
                          GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Amount *" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="amountField" promptText="e.g. 5000"
                           GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="320"/>

                <Label text="Fund" styleClass="form-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <ComboBox fx:id="fundCombo" prefWidth="320"
                          promptText="Select fund (optional)..."
                          GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="Currency *" styleClass="form-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <ComboBox fx:id="currencyCombo" prefWidth="320"
                          GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                <Label text="Payment Method" styleClass="form-label" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <TextField fx:id="methodField" promptText="e.g. Cash, Bank Transfer, JazzCash"
                           GridPane.rowIndex="5" GridPane.columnIndex="1" prefWidth="320"/>

                <Label text="Donation Date" styleClass="form-label" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <DatePicker fx:id="datePicker" prefWidth="320"
                            GridPane.rowIndex="6" GridPane.columnIndex="1"/>
            </GridPane>

            <HBox spacing="10">
                <Button text="Submit Donation" onAction="#submitForm" styleClass="btn-primary"/>
                <Button text="Clear Form"      onAction="#resetForm"  styleClass="btn-secondary"/>
            </HBox>

        </VBox>
    </VBox>

</VBox>
